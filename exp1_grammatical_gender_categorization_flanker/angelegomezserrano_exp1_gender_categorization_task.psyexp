      <Param name="Selected rows" updates="None" val="" valType="str"/>
      <Param name="conditions" updates="None" val="[{'pageN': 1, 'phase': 'end_of_practice', 'instruct_text': 'Ha completado la parte de práctica. Ahora da comienzo el experimento, es muy importante que responda con la mayor rapidez y precisión posibles. \nAntes de empezar, asegúrese de que se encuentra en un lugar cómodo y tranquilo y de que no se le molestará durante unos 15 minutos, ya que no podremos utilizar sus datos si no completa todos los ensayos. \nTendrá la oportunidad de hacer pausas a intervalos regulares durante el experimento. Cuando esté listo/a para iniciar la tarea, pulse la barra espaciadora o toque el botón que aparece a continuación.'}]" valType="str"/>
      <Param name="conditionsFile" updates="None" val="instructions_after_practice.xlsx" valType="str"/>
      <Param name="endPoints" updates="None" val="[0, 1]" valType="num"/>
      <Param name="isTrials" updates="None" val="False" valType="bool"/>
      <Param name="loopType" updates="None" val="sequential" valType="str"/>
      <Param name="nReps" updates="None" val="1" valType="code"/>
      <Param name="name" updates="None" val="end_of_practice_trials_pages" valType="code"/>
      <Param name="random seed" updates="None" val="" valType="code"/>
    </LoopInitiator>
    <Routine name="Instructions"/>
    <LoopTerminator name="end_of_practice_trials_pages"/>
