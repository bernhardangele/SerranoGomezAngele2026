5.087800000011921	EXP	consent_prescreening: model = {"surveys":[{"title":"Consentimiento informado","description":"Por favor, lea las condiciones del experimento antes de aceptarlas.","logo":"data:image/jpeg;base64,","focusFirstQuestionAutomatic":false,"pages":[{"name":"page1","elements":[{"type":"html","name":"block_1/Introduction","html":"<html>\n<head>\n    <meta content=\"text/html; charset=UTF-8\" http-equiv=\"content-type\">\n    <style type=\"text/css\">\n        @import url(https://themes.googleusercontent.com/fonts/css?kit=ZWjJg3Z-BmxuodZeCNuZK1XXWJorhxyFDZ_kYLKF3KU);\n        ol {block_1/\n            margin: 0;\n            padding: 0\n        }\n\n        table td, table th {\n            padding: 0\n        }\n\n        .c0 {\n            color: #000000;\n            font-weight: 400;\n            text-decoration: none;\n            vertical-align: baseline;\n            font-size: 12pt;\n            font-family: \"Nunito\";\n            font-style: normal\n        }\n\n        .c6 {\n            color: #000000;\n            font-weight: 700;\n            text-decoration: none;\n            vertical-align: baseline;\n            font-size: 15pt;\n            font-family: \"Nunito\";\n            font-style: normal\n        }\n\n        .c8 {\n            color: #000000;\n            font-weight: 400;\n            text-decoration: none;\n            vertical-align: baseline;\n            font-size: 11pt;\n            font-family: \"Arial\";\n            font-style: normal\n        }\n\n        .c4 {\n            color: #000000;\n            font-weight: 400;\n            text-decoration: none;\n            vertical-align: baseline;\n            font-size: 11pt;\n            font-family: \"Nunito\";\n            font-style: normal\n        }\n\n        .c1 {\n            padding-top: 0pt;\n            padding-bottom: 0pt;\n            line-height: 1.15;\n            orphans: 2;\n            widows: 2;\n            text-align: justify\n        }\n\n        .c7 {\n            padding-top: 0pt;\n            padding-bottom: 0pt;\n            line-height: 1.15;\n            orphans: 2;\n            widows: 2;\n            text-align: center\n        }\n\n        .c5 {\n            background-color: #ffffff;\n            max-width: 451.4pt;\n            padding: 72pt 72pt 72pt 72pt\n        }\n\n        .c2 {\n            font-size: 12pt;\n            font-family: \"Nunito\";\n            font-weight: 400\n        }\n\n        .c3 {\n            height: 11pt\n        }\n\n        .title {\n            padding-top: 0pt;\n            color: #000000;\n            font-size: 26pt;\n            padding-bottom: 3pt;\n            font-family: \"Arial\";\n            line-height: 1.15;\n            page-break-after: avoid;\n            orphans: 2;\n            widows: 2;\n            text-align: left\n        }\n\n        .subtitle {\n            padding-top: 0pt;\n            color: #666666;\n            font-size: 15pt;\n            padding-bottom: 16pt;\n            font-family: \"Arial\";\n            line-height: 1.15;\n            page-break-after: avoid;\n            orphans: 2;\n            widows: 2;\n            text-align: left\n        }\n\n        li {\n            color: #000000;\n            font-size: 11pt;\n            font-family: \"Arial\"\n        }\n\n        p {\n            margin: 0;\n            color: #000000;\n            font-size: 11pt;\n            font-family: \"Arial\"\n        }\n\n        h1 {\n            padding-top: 20pt;\n            color: #000000;\n            font-size: 20pt;\n            padding-bottom: 6pt;\n            font-family: \"Arial\";\n            line-height: 1.15;\n            page-break-after: avoid;\n            orphans: 2;\n            widows: 2;\n            text-align: left\n        }\n\n        h2 {\n            padding-top: 18pt;\n            color: #000000;\n            font-size: 16pt;\n            padding-bottom: 6pt;\n            font-family: \"Arial\";\n            line-height: 1.15;\n            page-break-after: avoid;\n            orphans: 2;\n            widows: 2;\n            text-align: left\n        }\n\n        h3 {\n            padding-top: 16pt;\n            color: #434343;\n            font-size: 14pt;\n            padding-bottom: 4pt;\n            font-family: \"Arial\";\n            line-height: 1.15;\n            page-break-after: avoid;\n            orphans: 2;\n            widows: 2;\n            text-align: left\n        }\n\n        h4 {\n            padding-top: 14pt;\n            color: #666666;\n            font-size: 12pt;\n            padding-bottom: 4pt;\n            font-family: \"Arial\";\n            line-height: 1.15;\n            page-break-after: avoid;\n            orphans: 2;\n            widows: 2;\n            text-align: left\n        }\n\n        h5 {\n            padding-top: 12pt;\n            color: #666666;\n            font-size: 11pt;\n            padding-bottom: 4pt;\n            font-family: \"Arial\";\n            line-height: 1.15;\n            page-break-after: avoid;\n            orphans: 2;\n            widows: 2;\n            text-align: left\n        }\n\n        h6 {\n            padding-top: 12pt;\n            color: #666666;\n            font-size: 11pt;\n            padding-bottom: 4pt;\n            font-family: \"Arial\";\n            line-height: 1.15;\n            page-break-after: avoid;\n            font-style: italic;\n            orphans: 2;\n            widows: 2;\n            text-align: left\n        }\n    </style>\n</head>\n<body class=\"c5 doc-content\">\n<div>\n    <p class=\"c3 c7\"><span class=\"c8\"></span></p>\n</div>\n<p class=\"c1\"><span class=\"c6\">Tarea de clasificación semántica</span></p>\n<p class=\"c1 c3\"><span class=\"c6\"></span></p>\n<p class=\"c1\"><span class=\"c0\">Usted está invitado a participar en un estudio que tiene como objetivo investigar diversos aspectos del procesamiento cognitivo humano. Tendrá que elegir si las palabras que aparecen en pantalla se refieren a animales (no humanos) o no. Este estudio está siendo llevado a cabo por Pablo Gómez (California State University San Bernardino, Palm Desert Campus).</span></p>\n<p class=\"c1 c3\"><span class=\"c0\"></span></p>\n<p class=\"c1\"><span class=\"c0\">Para participar responda a las siguientes preguntas y si es compatible con los requerimientos accederá a una serie de tareas en línea. La participación total en el estudio tomará aproximadamente 15-20 minutos. </span></p>\n<p class=\"c1 c3\"><span class=\"c0\"></span></p>\n<p class=\"c1\"><span class=\"c0\">Toda la información que proporcione será tratada de manera confidencial. Los datos recopilados serán anonimos y se almacenarán de manera segura. Los resultados del estudio se presentarán de manera agregada, sin identificar a ningún participante individualmente. </span></p>\n<p class=\"c1 c3\"><span class=\"c0\"></span></p>\n<p class=\"c1\"><span class=\"c0\">La participación en este estudio no le perjudicará ni desde el punto de vista médico ni académico. Además, tendrá una compensación económica mediante su cuenta en Prolific. Su participación en este estudio es completamente voluntaria. Puede decidir no participar o retirarse en cualquier momento sin ninguna penalización. Si decide retirar su participación, todos los datos asociados con usted serán eliminados. Si no finaliza el experimento no podrá acceder a la compensación económica. </span></p>\n<p class=\"c1 c3\"><span class=\"c0\"></span></p>\n<p class=\"c1\"><span class=\"c2\">Al marcar la casilla de abajo \"Aceptar las condiciones\", usted indica que ha leído y comprendido la información proporcionada anteriormente y que acepta participar en este estudio voluntariamente.<br><br></span></p>\n\n<!-- Final Paragraph -->\n<p class=\"c1\"><span class=\"c0\">Por favor, tenga en cuenta que el experimento cambiará su navegador a modo de pantalla completa. No salga del modo de pantalla completa antes de que se complete el estudio, ya que esto terminará el experimento de manera prematura. Después del experimento, el navegador volverá automáticamente al modo de ventana. <br><br>Antes de comenzar el experimento, por favor asegúrese de estar en un entorno tranquilo y de que no será molestado ni distraído durante los próximos 15-20 minutos.</span></p>\n</body>\n</html>\n","title":"Introduction"},{"type":"checkbox","name":"block_1/declare_consent","title":"Por favor, confirme que las declaraciones a continuación son correctas","isRequired":true,"requiredErrorText":"Debe confirmar las siguientes declaraciones para continuar. Si no puede confirmar las declaraciones, por favor devuelva la participación en Prolific. Es posible que pueda participar en otro momento cuando esté listo para confirmar las declaraciones.","validators":[{"type":"answercount","text":"Para poder participar, debe indicar que todas las declaraciones son verdaderas. Debe confirmar las siguientes declaraciones para continuar. Si no puede confirmar las declaraciones, por favor devuelva la participación en Prolific. Es posible que pueda participar en otro momento cuando esté listo para confirmar las declaraciones.","minCount":4,"maxCount":4}],"choices":[{"value":"over_18","text":"Tengo más de 18 años"},{"value":"comfortable","text":"Estoy sentado cómodamente en un lugar tranquilo, sin distracciones, durante los próximos 15-20 minutos."},{"value":"read_info","text":"He leído y comprendo la información proporcionada"},{"value":"consent_given","text":"Acepto las condiciones"}],"maxSelectedChoices":"","minSelectedChoices":""},{"type":"text","name":"block_1/age_years","title":"Edad en años","isRequired":true,"inputType":"number","min":18,"max":100},{"type":"radiogroup","name":"block_1/gender","title":"Género","choices":[{"value":"F","text":"Femenino"},{"value":"M","text":"Masculino"},{"value":"NB","text":"No binario"}],"showOtherItem":true,"otherText":"Otro"},{"type":"checkbox","name":"block_1/language_disorder","title":"¿Tiene algún trastorno relacionado con el lenguaje? Seleccione todos los que apliquen:","isRequired":true,"requiredErrorText":"Por favor, seleccione por lo menos una opción.","choices":[{"value":"reading","text":"Dificultad para leer"},{"value":"writing","text":"Dificultad para escribir"},{"value":"other","text":"Otro trastorno relacionado con el lenguaje"}],"showNoneItem":true,"noneText":"Ninguno","otherText":"Otro trastorno relacionado con el lenguaje","minSelectedChoices":1},{"type":"checkbox","name":"block_1/first_language","title":"¿Cuál es/son su(s) lengua(s) materna(s)?","isRequired":true,"requiredErrorText":"Tiene que seleccionar por lo menos un idioma.","validators":[{"type":"answercount","text":"Tiene que seleccionar por lo menos un idioma.","minCount":1}],"choices":[{"value":"english","text":"Inglés"},{"value":"spanish","text":"Español"}],"showOtherItem":true,"otherPlaceholder":"Especifique el idioma","otherText":"Otra(s) (especificar)","otherErrorText":"Por favor, especifique el idioma.","maxSelectedChoices":"","minSelectedChoices":""}]}]}],"embeddedData":[],"surveyFlow":{"name":"gg","type":"SEQUENTIAL_GROUP","nodes":[{"name":"block_1","type":"QUESTION_BLOCK","surveyIdx":0}],"isRootNode":true},"surveySettings":{"showPrevButton":false},"inQuestionRandomization":{},"questionsOrderRandomization":[],"questionSkipLogic":{},"questionsConverted":-1,"questionsTotal":-1,"logs":[],"surveyName":"Semantic categorization task consent and demographic information"}
